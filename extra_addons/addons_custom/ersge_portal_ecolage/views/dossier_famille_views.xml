<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_dossier_famille_form" model="ir.ui.view">
        <field name="name">ersge.dossier.famille.form</field>
        <field name="model">ersge.dossier.famille</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="alert alert-info">
                        <i class="fa fa-info-circle"></i>
                        Cliquez sur les sections ci-dessous pour les dérouler
                    </div>

                    <group>
                        <field name="name"/>
                        <field name="annee_scolaire"/>
                        <field name="family_id" options="{'no_create': True, 'no_create_edit': True}" readonly="1"/>
                        <field name="date_soumission"/>
                    </group>

                    <notebook>

                        <page string="Informations parents">
                            <group string="Représentant légal">
                                <field name="legal_representation" widget="radio"/>
                                <field name="legal_representation_other" invisible="legal_representation != 'other'" required="legal_representation == 'other'"/>
                            </group>
                            <group string="Cotisation annuelle">
                                <div class="alert alert-info">
                                    À l'Association en faveur de l'école Rudolf Steiner de Genève :
                                    Individuelle 40 CHF, Couple 60 CHF, Curateur/trice et Tuteur/trice Gratuit.
                                </div>
                                <field name="membership_fee_amount" readonly="1"/>
                            </group>
                            <group string="Père (ou parent 1)" invisible="legal_representation != 'both'">
                                <field name="parent1_firstname" required="legal_representation == 'both'"/>
                                <field name="parent1_lastname" required="legal_representation == 'both'"/>
                                <field name="parent1_email" widget="email" required="legal_representation == 'both'"/>
                                <field name="parent1_phone" widget="phone" required="legal_representation == 'both'"/>
                                <field name="parent1_phone_fixed" widget="phone"/>
                                <field name="parent1_phone_pro" widget="phone"/>
                                <field name="parent1_street" required="legal_representation == 'both'"/>
                                <field name="parent1_zip" required="legal_representation == 'both'"/>
                                <field name="parent1_city" required="legal_representation == 'both'"/>
                                <field name="parent1_country_id" required="legal_representation == 'both'"/>
                                <field name="parent1_profession" required="legal_representation == 'both'"/>
                                <field name="parent1_employeur"/>
                            </group>
                            <group string="Mère (ou parent 2)" invisible="legal_representation != 'both'">
                                <field name="parent2_firstname" required="legal_representation == 'both'"/>
                                <field name="parent2_lastname" required="legal_representation == 'both'"/>
                                <field name="parent2_email" widget="email" required="legal_representation == 'both'"/>
                                <field name="parent2_phone" widget="phone" required="legal_representation == 'both'"/>
                                <field name="parent2_phone_fixed" widget="phone"/>
                                <field name="parent2_phone_pro" widget="phone"/>
                                <field name="same_address_as_parent1"/>
                                <field name="parent2_street" invisible="same_address_as_parent1" required="legal_representation == 'both' and not same_address_as_parent1"/>
                                <field name="parent2_zip" invisible="same_address_as_parent1" required="legal_representation == 'both' and not same_address_as_parent1"/>
                                <field name="parent2_city" invisible="same_address_as_parent1" required="legal_representation == 'both' and not same_address_as_parent1"/>
                                <field name="parent2_country_id" invisible="same_address_as_parent1" required="legal_representation == 'both' and not same_address_as_parent1"/>
                                <field name="parent2_profession" required="legal_representation == 'both'"/>
                                <field name="parent2_employeur"/>
                            </group>
                            <group invisible="legal_representation == 'both' or legal_representation == False">
                                <field name="parent1_firstname" required="legal_representation in ('father_only', 'mother_only', 'other')"/>
                                <field name="parent1_lastname" required="legal_representation in ('father_only', 'mother_only', 'other')"/>
                                <field name="parent1_email" widget="email" required="legal_representation in ('father_only', 'mother_only', 'other')"/>
                                <field name="parent1_phone" widget="phone" required="legal_representation in ('father_only', 'mother_only', 'other')"/>
                                <field name="parent1_phone_fixed" widget="phone"/>
                                <field name="parent1_phone_pro" widget="phone"/>
                                <field name="parent1_street" required="legal_representation in ('father_only', 'mother_only', 'other')"/>
                                <field name="parent1_zip" required="legal_representation in ('father_only', 'mother_only', 'other')"/>
                                <field name="parent1_city" required="legal_representation in ('father_only', 'mother_only', 'other')"/>
                                <field name="parent1_country_id" required="legal_representation in ('father_only', 'mother_only', 'other')"/>
                                <field name="parent1_profession"/>
                                <field name="parent1_employeur"/>
                            </group>
                            <group string="Dépôt">
                                <div class="alert alert-info">Toute nouvelle famille doit verser un dépôt de 1000 CHF</div>
                                <field name="deposit_status" widget="radio"/>
                                <field name="deposit_amount" readonly="1"/>
                            </group>
                        </page>

                        <page string="Informations élève(s)">

                            <!-- Un seul champ : la liaison vers l'étudiant -->

                            <field name="student_line_ids" nolabel="1">
                                <list editable="bottom" create="1" delete="1">
                                    <field name="student_id" string="Élève" domain="[('family_id', '=', parent.family_id)]" options="{'no_create': False, 'no_create_edit': False, 'always_reload': True}" context="{'form_view_ref': 'ersge_portal_ecolage.view_ersge_student_form', 'default_family_id': parent.family_id}"/>
                                    <field name="sexe" required="1"/>
                                    <field name="image_rights" widget="boolean_toggle"/>
                                </list>
                            </field>


                            <!-- Info-bande comme avant -->
                            <div class="alert alert-info mt-3">
                                <i class="fa fa-info-circle"></i>
        Lors de diverses activités organisées par l'école, les élèves peuvent être amenés à être
        photographiés ou filmés.
                            </div>
                        </page>

                        <page string="Finances">
                            <group string="Ecolage">
                                <field name="employer_assistance" widget="radio"/>
                                <field name="send_invoice_to_employer" invisible="employer_assistance != 'yes'"/>
                                <field name="employer_id" invisible="employer_assistance != 'yes' or not send_invoice_to_employer" context="{'default_is_employer': True}" options="{'no_create': False}"/>
                            </group>



                            <group string="Forfaits">
                                <div class="alert alert-info" role="alert">
                                    <strong>CHOISISSEZ VOTRE FORFAIT</strong>
                                    <br/>
    FRAIS DE SCOLARITÉ + MATÉRIEL SCOLAIRE DE BASE + REPAS DE MIDI* BIO<br/>
    *Selon l'emploi du temps<br/>
                            <br/>
    Tarifs mensuels sur 12 mois - 1er versement au mois d'août. Frais non compris : Activités en dehors des murs de l'école (ex. voyage, échange linguistique...) et goûters aux jardins d'enfants.
                        </div>
                        <field name="student_line_ids" nolabel="1">
                            <list editable="bottom">
                                <field name="prenom" readonly="1"/>
                                <field name="nom" readonly="1"/>
                                <field name="forfait_id" options="{'no_create': True}"/>
                                <field name="forfait_montant_mensuel" readonly="1"/>
                            </list>
                        </field>

                        <field name="base_monthly_fee" readonly="1"/>
                    </group>

                    <group string="Réductions">

                        <strong>Demander une réduction en raison du nombre d’enfants inscrit à l'école et/ou une réduction d'ancienneté</strong>
                        <field name="reduction_requested" widget="boolean_button" options='{"terminology": "boolean"}'/>

                        <group invisible="not reduction_requested">
                            <group string="Demande de réduction en fonction du nombre d'enfants inscrits">
                                <div>
                                    <strong>Nombre d'enfants inscrits :</strong>
                                    <field name="actual_children_count" class="oe_inline"/>
                                </div>

                                <div>
                                    <div>
                                        <strong>Réduction maximale possible :</strong>
                                        <field name="max_children_discount" readonly="1"/>
 %
                                    </div>
                                    <label for="apply_children_discount" string="Vous sollicitez une réduction en raison du nombre d’enfants de votre famille inscrits dans l’école."/>
                                    <field name="apply_children_discount" nolabel="1"/>
                                    <div invisible="not apply_children_discount">
                                        <label for="monthly_fee_after_children"/>
                                        <field name="monthly_fee_after_children" readonly="1" class="oe_inline"/>
 CHF
                                    </div>
                                </div>
                            </group>

                            <group string="Demande de réduction en fonction de l'ancienneté">
                                <field name="seniority_years" widget="radio" options="{'horizontal': true}"/>
                                <div>
                                    <strong>Réduction maximale possible :</strong>
                                    <field name="max_seniority_discount" readonly="1"/>
 %
                                </div>
                                <label for="apply_seniority_discount" string="Vous sollicitez une réduction d’ancienneté relative au temps pendant lequel votre famille a contribué à l’école."/>
                                <field name="apply_seniority_discount" nolabel="1"/>
                                <div invisible="not apply_seniority_discount">
                                    <label for="monthly_fee_after_seniority"/>
                                    <field name="monthly_fee_after_seniority" readonly="1" class="oe_inline"/>
 CHF
                                </div>
                            </group>

                            <group string="Ajustez vos réductions">
                                <div>
                                    <strong>Sollicitez, en conscience, la réduction juste en fonction de votre situation.</strong>
                                </div>
                                <div>
                                    <strong>Vous pourriez solliciter la réduction maximale suivante (ancienneté et/ou nombres d'enfants dans l'école) :</strong>
                                    <!-- Affichage du pourcentage max, sans label -->
                                    <field name="max_total_discount" readonly="1"/>
 %
                                </div>
                                <div>
                                    <!-- Label déplacé ici, devant le montant -->
                                    <label for="monthly_fee_at_max" string="Total mensuel après rabais"/>
                                    <field name="monthly_fee_at_max" readonly="1" class="oe_inline"/>
 CHF
                                </div>
                                <!-- Le reste (requested_discount, etc.) est inchangé -->
                                <field name="requested_discount" string="Compte tenu de votre situation personnelle, vous sollicitez une réduction moindre, indiquez le pourcentage" required="1"/>
                                <div>
                                    <label for="monthly_fee_after_requested"/>
                                    <field name="monthly_fee_after_requested" readonly="1" class="oe_inline"/>
 CHF
                                </div>
                                <div class="alert alert-warning" role="alert" invisible="requested_discount &lt;= max_total_discount">
        Le pourcentage sollicité ne doit pas dépasser la réduction maximale !
                                </div>
                            </group>
                        </group>
                    </group>

                    <!-- Demande de réduction complémentaire -->
                    <group string="Réduction complémentaire">
                        <label for="additional_reduction_request" string="Je sollicite une demande de réduction complémentaire."/>
                        <field name="additional_reduction_request" widget="boolean_button" options='{"terminology": "boolean"}'/>

                        <group invisible="not additional_reduction_request">
                            <div class="alert alert-info">
                                <i class="fa fa-info-circle"></i>
    Merci de prendre impérativement connaissance de ce document :
                                <a href="/ersge_portal_ecolage/static/src/Procedure-demande-reduction-ecolage-2025-26.pdf" target="_blank">
        Demande de réduction d'écolage
                                </a>
                            </div>
                            <div>
                En cas d’impossibilité d'envoi de documents numériques, vous pouvez déposer une version papier
                de ces documents au secrétariat.
                            </div>

                            <group string="Situation financière">


                                <!-- Champ saisie utilisateur -->
                                <field name="gross_annual_income" string="Indiquer votre revenu brut annuel familial (CHF)"/>

                                <!-- Champ calculé automatiquement (lecture seule) -->
                                <field name="additional_reduction_income_percentage" string="Pourcentage que représente le tarif sur votre revenu annuel familial brut" widget="percentage" readonly="1"/>
                            </group>

                            <group string="Justificatifs">
                                <label for="tax_notice_attachment" string="Dernier avis de taxation"/>
                                <field name="tax_notice_attachment" filename="tax_notice_filename" attachment="tax_notice_attachment" help="Dernier avis de taxation (PDF, max 4MB)" nolabel="1"/>

                                <!-- Pour payslip_ids -->
                                <label for="payslip_ids" string="Trois dernières fiches de salaire"/>
                                <field name="payslip_ids" widget="many2many_binary" help="Vous pouvez télécharger plusieurs fichiers (max 8MB)" nolabel="1"/>
                            </group>
                            <group string="Lettre explicative" invisible="not additional_reduction_request">
                                <!-- Nouveau : choix du mode -->
                                <field name="explanatory_letter_mode" widget="radio" options="{'horizontal': true}"/>

                                <!-- Mode : téléchargement -->
                                <div invisible="explanatory_letter_mode != 'upload'">
                                    <field name="explanatory_letter_attachment" filename="explanatory_letter_filename" help="PDF, max 4MB"/>
                                    <field name="explanatory_letter_status" invisible="1" required="explanatory_letter_attachment != False"/>
                                </div>

                                <!-- Mode : écriture directe -->
                                <div invisible="explanatory_letter_mode != 'write'">
                                    <div class="alert alert-info">
                                        <i class="fa fa-info-circle"/>
 
            Veuillez décrire votre situation familiale ci-dessous :
                                    </div>
                                    <field name="explanatory_letter_text" placeholder="Décrivez votre situation familiale, les difficultés, vos motivations..." nolabel="1"/>
                                    <field name="explanatory_letter_status" invisible="1"/>
                                </div>
                            </group>
                            <!-- Budget familial : option téléchargement ou saisie en ligne -->
                            <group string="Budget familial">
                                <field name="budget_method" widget="radio" options="{'horizontal': true}"/>
                                <div invisible="budget_method != 'upload'">
                                    <field name="budget_attachment" filename="budget_attachment_filename" help="Téléchargez votre budget au format PDF (max 4MB)"/>
                                </div>

                                <div invisible="budget_method != 'online'">
                                    <div style="overflow-x: auto;">

                                        <h4>Entrées</h4>
                                        <field name="budget_income_line_ids" nolabel="1">
                                            <list editable="bottom" create="false" delete="false">
                                                <field name="category_id" string="Catégorie" readonly="1"/>
                                                <field name="montant_madame" string="Madame" widget="monetary" aggregate="sum"/>
                                                <field name="montant_monsieur" string="Monsieur" widget="monetary" aggregate="sum"/>
                                            </list>
                                        </field>

                                        <h4>Sorties</h4>
                                        <field name="budget_expense_line_ids" nolabel="1">
                                            <list editable="bottom" create="false" delete="false">
                                                <field name="category_id" string="Catégorie" readonly="1"/>
                                                <field name="montant_madame" string="Madame" widget="monetary" aggregate="sum"/>
                                                <field name="montant_monsieur" string="Monsieur" widget="monetary" aggregate="sum"/>
                                            </list>
                                        </field>

                                        <group string="Totaux du budget">
                                            <group string="Revenus">
                                                <field name="total_revenus_madame" widget="monetary"/>
                                                <field name="total_revenus_monsieur" widget="monetary"/>
                                                <field name="total_revenus" widget="monetary"/>
                                            </group>
                                            <group string="Charges">
                                                <field name="total_charges_madame" widget="monetary"/>
                                                <field name="total_charges_monsieur" widget="monetary"/>
                                                <field name="total_charges" widget="monetary"/>
                                            </group>
                                            <field name="solde" widget="monetary" decoration-danger="solde &lt; 0"/>
                                        </group>
                                    </div>
                                </div>

                                <group string="Proposition">
                                    <label for="proposed_monthly_amount" string="Je propose à la CEF un montant mensuel"/>
                                    <field name="proposed_monthly_amount" string="Merci d'indiquer l'écolage mensuel que vous proposez"/>
                                    <div>
                                        <strong>Total proposé :</strong>
                                        <field name="proposed_monthly_amount" readonly="1" class="oe_inline"/>
 CHF
                                    </div>
                                </group>
                            </group>
                        </group>
                    </group>
                </page>
                <page string="Parascolaire">
                    <group string="Demande parascolaire">
                        <field name="after_school_request" widget="radio"/>
                        <field name="after_school_line_ids" invisible="after_school_request != 'yes'">
                            <list editable="bottom">
                                <field name="selected" widget="boolean_toggle"/>
                                <field name="student_id" domain="[('family_id', '=', parent.family_id)]" options="{'no_create': True}" required="1" readonly="1" />
                                <field name="accueil_type" required="1" widget="selection" invisible="not selected"/>
                                <field name="lundi_midi" invisible="accueil_type == False"/>
                                <field name="lundi_soir" invisible="accueil_type == False"/>
                                <field name="lundi_cirque" invisible="accueil_type != 'classe'"/>
                                <field name="mardi_midi"/>
                                <field name="mardi_soir"/>
                                <field name="mardi_cirque" invisible="accueil_type != 'classe'"/>
                                <field name="mercredi_midi"/>
                                <field name="mercredi_soir"/>
                                <field name="mercredi_cirque" invisible="accueil_type != 'classe'"/>
                                <field name="jeudi_midi"/>
                                <field name="jeudi_soir"/>
                                <field name="jeudi_cirque" invisible="accueil_type != 'classe'"/>
                                <field name="vendredi_midi"/>
                                <field name="vendredi_soir"/>
                                <field name="vendredi_cirque" invisible="accueil_type != 'classe'"/>
                                <field name="montant_mensuel" aggregate="sum" readonly="1"/>
                            </list>
                        </field>
                        <field name="total_monthly_after_school" readonly="1" invisible="after_school_request == 'no'" class="oe_inline"/>
                    </group>
                </page>




                <page string="Récapitulatif">
                    <group string="Mensuel">
                        <label for="total_monthly_tuition"/>
                        <field name="total_monthly_tuition"/>
                        <label for="total_monthly_after_school"/>
                        <field name="total_monthly_after_school"/>
                        <label for="total_monthly"/>
                        <field name="total_monthly"/>
                    </group>
                    <group string="Annuel">
                        <label for="total_annual_tuition"/>
                        <field name="total_annual_tuition"/>
                        <label for="total_annual_after_school"/>
                        <field name="total_annual_after_school"/>
                        <label for="membership_fee_amount"/>
                        <field name="membership_fee_amount"/>
                        <label for="deposit_amount"/>
                        <field name="deposit_amount"/>
                        <label for="total_annual"/>
                        <field name="total_annual"/>
                    </group>
                </page>

                <page string="Mentions">
                    <field name="legal_notice" widget="html" readonly="1"/>
                    <field name="technical_contact" widget="html" readonly="1"/>
                </page>

            </notebook>
        </sheet>
    </form>
</field>
</record>

<record id="view_dossier_famille_list" model="ir.ui.view">
<field name="name">ersge.dossier.famille.list</field>
<field name="model">ersge.dossier.famille</field>
<field name="arch" type="xml">
    <list>
        <field name="display_name"/>
        <field name="annee_scolaire"/>
        <field name="state" widget="badge"/>
        <field name="date_soumission"/>
    </list>
</field>
</record>

<record id="action_dossier_famille" model="ir.actions.act_window">
<field name="name">Dossiers famille</field>
<field name="res_model">ersge.dossier.famille</field>
<field name="view_mode">list,form</field>
<field name="context">{}</field>
</record>

<menuitem id="menu_ersge_root" name="Écolage" sequence="10"/>

</odoo>