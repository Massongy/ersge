<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_dossier_famille_form" model="ir.ui.view">
        <field name="name">ersge.dossier.famille.form</field>
        <field name="model">ersge.dossier.famille</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="alert alert-info">
                        <i class="fa fa-info-circle"></i>
                        Cliquez sur les sections ci-dessous pour les dérouler
                    </div>

                    <group>
                        <field name="name"/>
                        <field name="annee_scolaire"/>
                        <field name="family_id"/>
                        <field name="date_soumission"/>
                    </group>

                    <notebook>
                        <page string="Informations parents">
                            <group string="Représentant légal">
                                <field name="legal_representation" widget="radio"/>
                                <field name="legal_representation_other" string="Autre, précisez :" invisible="legal_representation != 'other'" required="legal_representation == 'other'"/>
                            </group>

                            <group string="Cotisation annuelle">
                                <div class="alert alert-info">
        À l'Association en faveur de l'école Rudolf Steiner de Genève : 
        Individuelle 40 CHF, Couple 60 CHF, Curateur/trice et Tuteur/trice Gratuit.
                                </div>
                                <field name="membership_fee_amount" readonly="1"/>
                            </group>



                            <!-- Cas : les deux parents -->
                            <group string="Père (ou parent 1)" invisible="legal_representation != 'both'">
                                <field name="parent1_id" options="{'no_create': True, 'no_create_edit': True}" required="legal_representation == 'both'"/>
                                <field name="parent1_firstname" string="Prénom" required="legal_representation == 'both'"/>
                                <field name="parent1_lastname" string="Nom" required="legal_representation == 'both'"/>
                                <field name="parent1_email" string="Email" widget="email" required="legal_representation == 'both'"/>
                                <field name="parent1_phone" string="Téléphone mobile" widget="phone" required="legal_representation == 'both'"/>
                                <field name="parent1_phone_fixed" string="Téléphone fixe" widget="phone"/>
                                <field name="parent1_phone_pro" string="Téléphone pro" widget="phone"/>
                                <field name="parent1_street" string="Adresse" required="legal_representation == 'both'"/>
                                <field name="parent1_zip" string="Code Postal" required="legal_representation == 'both'"/>
                                <field name="parent1_city" string="Ville" required="legal_representation == 'both'"/>
                                <field name="parent1_country_id" string="Pays" required="legal_representation == 'both'"/>
                                <field name="parent1_profession" string="Profession" required="legal_representation == 'both'"/>
                                <field name="parent1_employeur" string="Employeur"/>
                            </group>

                            <group string="Mère (ou parent 2)" invisible="legal_representation != 'both'">
                                <field name="parent2_id" options="{'no_create': True, 'no_create_edit': True}" required="legal_representation == 'both'"/>
                                <field name="parent2_firstname" string="Prénom" required="legal_representation == 'both'"/>
                                <field name="parent2_lastname" string="Nom" required="legal_representation == 'both'"/>
                                <field name="parent2_email" string="Email" widget="email" required="legal_representation == 'both'"/>
                                <field name="parent2_phone" string="Téléphone mobile" widget="phone" required="legal_representation == 'both'"/>
                                <field name="parent2_phone_fixed" string="Téléphone fixe" widget="phone"/>
                                <field name="parent2_phone_pro" string="Téléphone pro" widget="phone"/>
                                <field name="same_address_as_parent1"/>
                                <field name="parent2_street" string="Adresse" invisible="same_address_as_parent1 == True" required="legal_representation == 'both' and same_address_as_parent1 == False"/>
                                <field name="parent2_zip" string="Code Postal" invisible="same_address_as_parent1 == True" required="legal_representation == 'both' and same_address_as_parent1 == False"/>
                                <field name="parent2_city" string="Ville" invisible="same_address_as_parent1 == True" required="legal_representation == 'both' and same_address_as_parent1 == False"/>
                                <field name="parent2_country_id" string="Pays" invisible="same_address_as_parent1 == True" required="legal_representation == 'both' and same_address_as_parent1 == False"/>
                                <field name="parent2_profession" string="Profession" required="legal_representation == 'both'"/>
                                <field name="parent2_employeur" string="Employeur"/>
                            </group>

                            <!-- Cas : père seul, mère seule, ou autre — groupe sans titre -->
                            <group invisible="legal_representation == 'both' or legal_representation == False">
                                <field name="parent1_id" string="Rechercher un contact existant" options="{'no_create': True, 'no_create_edit': True}" required="legal_representation in ('father_only', 'mother_only', 'other')"/>
                                <field name="parent1_firstname" string="Prénom" required="legal_representation in ('father_only', 'mother_only', 'other')"/>
                                <field name="parent1_lastname" string="Nom" required="legal_representation in ('father_only', 'mother_only', 'other')"/>
                                <field name="parent1_email" string="Email" widget="email" required="legal_representation in ('father_only', 'mother_only', 'other')"/>
                                <field name="parent1_phone" string="Téléphone mobile" widget="phone" required="legal_representation in ('father_only', 'mother_only', 'other')"/>
                                <field name="parent1_phone_fixed" string="Téléphone fixe" widget="phone"/>
                                <field name="parent1_phone_pro" string="Téléphone pro" widget="phone"/>
                                <field name="parent1_street" string="Adresse" required="legal_representation in ('father_only', 'mother_only', 'other')"/>
                                <field name="parent1_zip" string="Code Postal" required="legal_representation in ('father_only', 'mother_only', 'other')"/>
                                <field name="parent1_city" string="Ville" required="legal_representation in ('father_only', 'mother_only', 'other')"/>
                                <field name="parent1_country_id" string="Pays" required="legal_representation in ('father_only', 'mother_only', 'other')"/>
                                <field name="parent1_profession" string="Profession"/>
                                <field name="parent1_employeur" string="Employeur"/>
                            </group>

                            <group string="Dépôt">
                                <div class="alert alert-info">Toute nouvelle famille doit verser un dépôt de 1000 CHF</div>
                                <field name="deposit_status" widget="radio"/>
                                <field name="deposit_amount" readonly="1"/>
                            </group>
                        </page>

                        <page string="Informations élève(s)">

                            <group>
                                <field name="nb_students" string="Nombre d'enfant(s) à inscrire" readonly="1"/>
                            </group>

                            <field name="student_line_ids" nolabel="1">
                                <list editable="bottom">
                                    <field name="student_id" optional="hide"/>
                                    <field name="prenom" string="Prénom" required="1"/>
                                    <field name="nom" string="Nom" required="1"/>
                                    <field name="date_naissance" string="Date de naissance" required="1"/>
                                    <field name="sexe" string="Sexe" required="1"/>
                                    <field name="image_rights" string="Droit à l'image" widget="boolean_toggle"/>
                                    <field name="classe" string="Classe"/>
                                    <field name="forfait_id" string="Forfait" options="{'no_create': True, 'no_create_edit': True}"/>
                                </list>
                            </field>

                            <div class="alert alert-info mt-3">
                                <i class="fa fa-info-circle"></i>
        Lors de diverses activités organisées par l'école, les élèves peuvent être amenés à être
        photographiés ou filmés. Dans le cas de votre accord au droit à l'image, ces images pourront
        être utilisées à des fins pédagogiques ou pour notre communication en toute vigilance et
        respect pour les élèves.
                            </div>

                        </page>

                        <page string="Finances">
                            <group string="Aide employeur">
                                <field name="employer_assistance"/>
                                <field name="send_invoice_to_employer" invisible="employer_assistance == 'no'"/>
                                <field name="employer_id" invisible="employer_assistance == 'no'"/>
                            </group>
                            <group string="Réductions">
                                <field name="reduction_children"/>
                                <field name="reduction_children_applied" invisible="reduction_children == False"/>
                                <field name="reduction_seniority"/>
                                <field name="reduction_seniority_applied" invisible="reduction_seniority == False"/>
                                <field name="total_reduction_percentage" readonly="1"/>
                            </group>
                            <group string="Réduction complémentaire">
                                <field name="additional_reduction_request" widget="radio"/>
                                <field name="additional_reduction_income_percentage" invisible="additional_reduction_request == 'no'" required="additional_reduction_request == 'yes'"/>
                                <field name="annual_gross_income" invisible="additional_reduction_request == 'no'"/>
                                <field name="proposed_monthly_amount" invisible="additional_reduction_request == 'no'"/>
                            </group>
                        </page>

                        <page string="Engagements">
                            <group string="Parascolaire">
                                <field name="after_school_request"/>
                                <field name="after_school_line_ids">
                                    <list editable="bottom">
                                        <field name="extracurricular_id"/>
                                        <field name="student_id"/>
                                        <field name="schedule"/>
                                        <field name="montant_mensuel" sum="Total mensuel"/>
                                    </list>
                                </field>
                                <field name="total_monthly_after_school" readonly="1" invisible="after_school_request == 'no'"/>
                            </group>
                            <group string="Solidarité">
                                <field name="solidarity_request" widget="radio"/>
                                <field name="solidarity_percentage" invisible="solidarity_request == 'no'" required="solidarity_request == 'yes'"/>
                            </group>
                            <group string="Parrainage">
                                <field name="sponsorship_request" widget="radio"/>
                                <field name="sponsorship_type" invisible="sponsorship_request == 'no'"/>
                                <field name="sponsorship_id" invisible="sponsorship_request == 'no'"/>
                                <field name="multi_billing_request"/>
                                <field name="billing_line_ids" invisible="multi_billing_request == False">
                                    <list editable="bottom">
                                        <field name="partner_id"/>
                                        <field name="percentage"/>
                                    </list>
                                </field>
                            </group>
                            <group string="Cotisation">
                                <field name="membership_fee" widget="radio"/>
                                <field name="membership_fee_amount" readonly="1"/>
                                <field name="deposit_status" widget="radio"/>
                                <field name="deposit_amount" readonly="1"/>
                            </group>
                            <group string="Modalités">
                                <field name="payment_terms" widget="radio"/>
                                <div class="alert alert-warning" invisible="additional_reduction_request == 'no'">
                                    ⚠️ La remise 2% est incompatible avec la réduction complémentaire
                                </div>
                            </group>
                        </page>

                        <page string="Récapitulatif">
                            <group string="Mensuel" col="2">
                                <label for="total_monthly_tuition" string="Total mensuel écolage"/>
                                <field name="total_monthly_tuition" class="text-right"/>
                                <label for="total_monthly_after_school" string="Total mensuel parascolaire"/>
                                <field name="total_monthly_after_school" class="text-right"/>
                                <label for="total_monthly" string="Total mensuel combiné"/>
                                <field name="total_monthly" class="text-right text-bold"/>
                            </group>
                            <group string="Annuel" col="2">
                                <label for="total_annual_tuition" string="Total annuel écolage"/>
                                <field name="total_annual_tuition" class="text-right"/>
                                <label for="total_annual_after_school" string="Total annuel parascolaire"/>
                                <field name="total_annual_after_school" class="text-right"/>
                                <label for="membership_fee_amount" string="Cotisation annuelle"/>
                                <field name="membership_fee_amount" class="text-right"/>
                                <label for="deposit_amount" string="Dépôt"/>
                                <field name="deposit_amount" class="text-right"/>
                                <label for="total_annual" string="Total annuel global"/>
                                <field name="total_annual" class="text-right text-bold"/>
                            </group>
                        </page>

                        <page string="Mentions">
                            <field name="legal_notice" widget="html" readonly="1"/>
                            <field name="technical_contact" widget="html" readonly="1"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_dossier_famille_list" model="ir.ui.view">
        <field name="name">ersge.dossier.famille.list</field>
        <field name="model">ersge.dossier.famille</field>
        <field name="arch" type="xml">
            <list>
                <field name="display_name"/>
                <field name="annee_scolaire"/>
                <field name="state" widget="badge"/>
                <field name="date_soumission"/>
            </list>
        </field>
    </record>

    <!-- 1. L'ACTION : ce qui s'ouvre -->

    <record id="action_dossier_famille" model="ir.actions.act_window">
        <field name="name">Dossiers famille</field>
        <field name="res_model">ersge.dossier.famille</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- 2. LE MENU : où ça apparaît -->

    <menuitem id="menu_ersge_root" name="Écolage" sequence="10"/>
    <menuitem id="menu_ersge_dossier" name="Dossiers famille" parent="menu_ersge_root" action="action_dossier_famille" sequence="10"/>

</odoo>