<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="portal_dossier_form_complete" name="Formulaire complet dossier écolage">
        <t t-call="portal.portal_layout">
            <t t-set="page_title">Dossier d'écolage</t>
            <div class="container mt-4">
                <form method="post" action="" enctype="multipart/form-data">
                    <input type="hidden" name="csrf_token" t-att-value="csrf_token"/>

                    <!-- En-tête dossier -->
                    <div class="card mb-4">
                        <div class="card-header bg-primary text-white">
                            <h5 class="mb-0">
                                <i class="fa fa-folder me-2"/>
                                Dossier d'écolage
                            </h5>
                        </div>
                        <div class="card-body">
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold">Référence</label>
                                    <div class="form-control bg-light">
                                        <t t-out="dossier.name"/>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold">Année scolaire</label>
                                    <div class="form-control bg-light">
                                        <t t-out="dossier.annee_scolaire"/>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold">Famille</label>
                                    <div class="form-control bg-light">
                                        <t t-out="dossier.family_id.name"/>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold">Date de soumission</label>
                                    <div class="form-control bg-light">
                                        <t t-out="dossier.date_soumission"/>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- ACCORDÉON -->
                    <div class="accordion mb-4" id="dossierAccordion">

                        <!-- Section 1 : Informations parents -->
                        <div class="accordion-item border mb-3 rounded shadow-sm">
                            <h2 class="accordion-header" id="headingParents">
                                <button class="accordion-button rounded" type="button" data-bs-toggle="collapse" data-bs-target="#collapseParents" aria-expanded="true" aria-controls="collapseParents">
                                    <i class="fa fa-users me-2 text-primary"/>
                                    <strong>Informations parents</strong>
                                </button>
                            </h2>
                            <div id="collapseParents" class="accordion-collapse collapse show" aria-labelledby="headingParents">
                                <div class="accordion-body">

                                    <div class="alert alert-info">
                                        <i class="fa fa-info-circle me-2"/>
                                        À l'Association en faveur de l'école Rudolf Steiner de Genève :
                                        <strong>Individuelle 40 CHF</strong>,
                                        <strong>Couple 60 CHF</strong>,
                                        Curateur/trice et Tuteur/trice <strong>Gratuit</strong>.
                                    </div>

                                    <!-- Représentant légal -->
                                    <div class="card mb-4">
                                        <div class="card-header fw-semibold bg-light">
                                            <i class="fa fa-gavel me-2"/>
Représentant légal
                                        </div>
                                        <div class="card-body">
                                            <label class="form-label fw-semibold">
                                                Qui exerce la représentation légale ?
                                                <span class="text-danger">*</span>
                                            </label>
                                            <div class="d-flex flex-column gap-2">
                                                <div class="form-check">
                                                    <input class="form-check-input" type="radio" name="legal_representation" id="rep_both" value="both" t-att-checked="dossier.legal_representation == 'both'"/>
                                                    <label class="form-check-label" for="rep_both">Les deux parents</label>
                                                </div>
                                                <div class="form-check">
                                                    <input class="form-check-input" type="radio" name="legal_representation" id="rep_parent1" value="parent1" t-att-checked="dossier.legal_representation == 'parent1'"/>
                                                    <label class="form-check-label" for="rep_parent1">Parent 1 uniquement</label>
                                                </div>
                                                <div class="form-check">
                                                    <input class="form-check-input" type="radio" name="legal_representation" id="rep_parent2" value="parent2" t-att-checked="dossier.legal_representation == 'parent2'"/>
                                                    <label class="form-check-label" for="rep_parent2">Parent 2 uniquement</label>
                                                </div>
                                                <div class="form-check">
                                                    <input class="form-check-input" type="radio" name="legal_representation" id="rep_other" value="other" t-att-checked="dossier.legal_representation == 'other'"/>
                                                    <label class="form-check-label" for="rep_other">Autre</label>
                                                </div>
                                            </div>
                                            <div class="mt-3" id="block_other" t-att-style="'display:' + ('block' if dossier.legal_representation == 'other' else 'none')">
                                                <div class="card mb-4">
                                                    <div class="card-header fw-semibold bg-light">
                                                        <i class="fa fa-user me-2 text-warning"/>
Autre représentant légal
                                                    </div>
                                                    <div class="card-body">
                                                        <div class="row g-3">
                                                            <div class="col-12">
                                                                <label class="form-label fw-semibold" for="legal_representation_other">
                        Précisez <span class="text-danger">*</span>
                                                                </label>
                                                                <input type="text" class="form-control" name="legal_representation_other" id="legal_representation_other" placeholder="Ex : Tuteur légal, Curateur..." t-att-value="dossier.legal_representation_other or ''"/>
                                                            </div>
                                                            <div class="col-md-6">
                                                                <label class="form-label fw-semibold">Prénom</label>
                                                                <input type="text" class="form-control" name="parent1_firstname" t-att-value="dossier.parent1_firstname or ''"/>
                                                            </div>
                                                            <div class="col-md-6">
                                                                <label class="form-label fw-semibold">Nom</label>
                                                                <input type="text" class="form-control" name="parent1_lastname" t-att-value="dossier.parent1_lastname or ''"/>
                                                            </div>
                                                            <div class="col-md-6">
                                                                <label class="form-label fw-semibold">Email</label>
                                                                <input type="email" class="form-control" name="parent1_email" t-att-value="dossier.parent1_email or ''"/>
                                                            </div>
                                                            <div class="col-md-6">
                                                                <label class="form-label fw-semibold">Tél. mobile</label>
                                                                <input type="tel" class="form-control" name="parent1_phone" t-att-value="dossier.parent1_phone or ''"/>
                                                            </div>
                                                            <div class="col-md-6">
                                                                <label class="form-label fw-semibold">Tél. fixe</label>
                                                                <input type="tel" class="form-control" name="parent1_phone_fixed" t-att-value="dossier.parent1_phone_fixed or ''"/>
                                                            </div>
                                                            <div class="col-md-6">
                                                                <label class="form-label fw-semibold">Tél. professionnel</label>
                                                                <input type="tel" class="form-control" name="parent1_phone_pro" t-att-value="dossier.parent1_phone_pro or ''"/>
                                                            </div>
                                                            <div class="col-12">
                                                                <label class="form-label fw-semibold">Rue</label>
                                                                <input type="text" class="form-control" name="parent1_street" t-att-value="dossier.parent1_street or ''"/>
                                                            </div>
                                                            <div class="col-md-4">
                                                                <label class="form-label fw-semibold">NPA</label>
                                                                <input type="text" class="form-control" name="parent1_zip" t-att-value="dossier.parent1_zip or ''"/>
                                                            </div>
                                                            <div class="col-md-8">
                                                                <label class="form-label fw-semibold">Ville</label>
                                                                <input type="text" class="form-control" name="parent1_city" t-att-value="dossier.parent1_city or ''"/>
                                                            </div>
                                                            <div class="col-md-6">
                                                                <label class="form-label fw-semibold">Profession</label>
                                                                <input type="text" class="form-control" name="parent1_profession" t-att-value="dossier.parent1_profession or ''"/>
                                                            </div>
                                                            <div class="col-md-6">
                                                                <label class="form-label fw-semibold">Employeur</label>
                                                                <input type="text" class="form-control" name="parent1_employeur" t-att-value="dossier.parent1_employeur or ''"/>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- Parent 1 -->
                                    <div id="block_parent1" t-att-style="'display:' + ('block' if dossier.legal_representation in ('both','parent1') else 'none')">
                                        <div class="card mb-4">
                                            <div class="card-header fw-semibold bg-light">
                                                <i class="fa fa-user me-2 text-primary"/>
Père / Parent 1
                                            </div>
                                            <div class="card-body">
                                                <div class="row g-3">
                                                    <div class="col-md-6">
                                                        <label class="form-label fw-semibold">Prénom</label>
                                                        <input type="text" class="form-control" name="parent1_firstname" t-att-value="dossier.parent1_firstname or ''"/>
                                                    </div>
                                                    <div class="col-md-6">
                                                        <label class="form-label fw-semibold">Nom</label>
                                                        <input type="text" class="form-control" name="parent1_lastname" t-att-value="dossier.parent1_lastname or ''"/>
                                                    </div>
                                                    <div class="col-md-6">
                                                        <label class="form-label fw-semibold">Email</label>
                                                        <input type="email" class="form-control" name="parent1_email" t-att-value="dossier.parent1_email or ''"/>
                                                    </div>
                                                    <div class="col-md-6">
                                                        <label class="form-label fw-semibold">Tél. mobile</label>
                                                        <input type="tel" class="form-control" name="parent1_phone" t-att-value="dossier.parent1_phone or ''"/>
                                                    </div>
                                                    <div class="col-md-6">
                                                        <label class="form-label fw-semibold">Tél. fixe</label>
                                                        <input type="tel" class="form-control" name="parent1_phone_fixed" t-att-value="dossier.parent1_phone_fixed or ''"/>
                                                    </div>
                                                    <div class="col-md-6">
                                                        <label class="form-label fw-semibold">Tél. professionnel</label>
                                                        <input type="tel" class="form-control" name="parent1_phone_pro" t-att-value="dossier.parent1_phone_pro or ''"/>
                                                    </div>
                                                    <div class="col-12">
                                                        <label class="form-label fw-semibold">Rue</label>
                                                        <input type="text" class="form-control" name="parent1_street" t-att-value="dossier.parent1_street or ''"/>
                                                    </div>
                                                    <div class="col-md-4">
                                                        <label class="form-label fw-semibold">NPA</label>
                                                        <input type="text" class="form-control" name="parent1_zip" t-att-value="dossier.parent1_zip or ''"/>
                                                    </div>
                                                    <div class="col-md-8">
                                                        <label class="form-label fw-semibold">Ville</label>
                                                        <input type="text" class="form-control" name="parent1_city" t-att-value="dossier.parent1_city or ''"/>
                                                    </div>
                                                    <div class="col-md-6">
                                                        <label class="form-label fw-semibold">Profession</label>
                                                        <input type="text" class="form-control" name="parent1_profession" t-att-value="dossier.parent1_profession or ''"/>
                                                    </div>
                                                    <div class="col-md-6">
                                                        <label class="form-label fw-semibold">Employeur</label>
                                                        <input type="text" class="form-control" name="parent1_employeur" t-att-value="dossier.parent1_employeur or ''"/>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- Parent 2 -->
                                    <div id="block_parent2" t-att-style="'display:' + ('block' if dossier.legal_representation in ('both','parent2') else 'none')">
                                        <div class="card mb-4">
                                            <div class="card-header fw-semibold bg-light">
                                                <i class="fa fa-user me-2 text-success"/>
Mère / Parent 2
                                            </div>
                                            <div class="card-body">
                                                <div class="row g-3">
                                                    <div class="col-md-6">
                                                        <label class="form-label fw-semibold">Prénom</label>
                                                        <input type="text" class="form-control" name="parent2_firstname" t-att-value="dossier.parent2_firstname or ''"/>
                                                    </div>
                                                    <div class="col-md-6">
                                                        <label class="form-label fw-semibold">Nom</label>
                                                        <input type="text" class="form-control" name="parent2_lastname" t-att-value="dossier.parent2_lastname or ''"/>
                                                    </div>
                                                    <div class="col-md-6">
                                                        <label class="form-label fw-semibold">Email</label>
                                                        <input type="email" class="form-control" name="parent2_email" t-att-value="dossier.parent2_email or ''"/>
                                                    </div>
                                                    <div class="col-md-6">
                                                        <label class="form-label fw-semibold">Tél. mobile</label>
                                                        <input type="tel" class="form-control" name="parent2_phone" t-att-value="dossier.parent2_phone or ''"/>
                                                    </div>
                                                    <div class="col-md-6">
                                                        <label class="form-label fw-semibold">Tél. fixe</label>
                                                        <input type="tel" class="form-control" name="parent2_phone_fixed" t-att-value="dossier.parent2_phone_fixed or ''"/>
                                                    </div>
                                                    <div class="col-md-6">
                                                        <label class="form-label fw-semibold">Tél. professionnel</label>
                                                        <input type="tel" class="form-control" name="parent2_phone_pro" t-att-value="dossier.parent2_phone_pro or ''"/>
                                                    </div>
                                                    <div class="col-12">
                                                        <div class="form-check">
                                                            <input class="form-check-input" type="checkbox" name="same_address_as_parent1" id="same_address_as_parent1" value="1" t-att-checked="dossier.same_address_as_parent1"/>
                                                            <label class="form-check-label fw-semibold" for="same_address_as_parent1">
                                                                Même adresse que le parent 1
                                                            </label>
                                                        </div>
                                                    </div>
                                                    <div id="block_parent2_address" class="col-12" t-att-style="'display:' + ('none' if dossier.same_address_as_parent1 else 'block')">
                                                        <div class="row g-3">
                                                            <div class="col-12">
                                                                <label class="form-label fw-semibold">Rue</label>
                                                                <input type="text" class="form-control" name="parent2_street" t-att-value="dossier.parent2_street or ''"/>
                                                            </div>
                                                            <div class="col-md-4">
                                                                <label class="form-label fw-semibold">NPA</label>
                                                                <input type="text" class="form-control" name="parent2_zip" t-att-value="dossier.parent2_zip or ''"/>
                                                            </div>
                                                            <div class="col-md-8">
                                                                <label class="form-label fw-semibold">Ville</label>
                                                                <input type="text" class="form-control" name="parent2_city" t-att-value="dossier.parent2_city or ''"/>
                                                            </div>
                                                        </div>
                                                    </div>
                                                    <div class="col-md-6">
                                                        <label class="form-label fw-semibold">Profession</label>
                                                        <input type="text" class="form-control" name="parent2_profession" t-att-value="dossier.parent2_profession or ''"/>
                                                    </div>
                                                    <div class="col-md-6">
                                                        <label class="form-label fw-semibold">Employeur</label>
                                                        <input type="text" class="form-control" name="parent2_employeur" t-att-value="dossier.parent2_employeur or ''"/>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- Dépôt -->
                                    <div class="card mb-2">
                                        <div class="card-header fw-semibold bg-light">
                                            <i class="fa fa-university me-2"/>
Dépôt
                                        </div>
                                        <div class="card-body">
                                            <div class="alert alert-info">
                                                Toute nouvelle famille doit verser un dépôt de <strong>1000 CHF</strong>.
                                            </div>
                                            <label class="form-label fw-semibold">Statut du dépôt</label>
                                            <div class="d-flex flex-column gap-2">
                                                <div class="form-check">
                                                    <input class="form-check-input" type="radio" name="deposit_status" value="paid" t-att-checked="dossier.deposit_status == 'paid'"/>
                                                    <label class="form-check-label">Déjà versé</label>
                                                </div>
                                                <div class="form-check">
                                                    <input class="form-check-input" type="radio" name="deposit_status" value="pending" t-att-checked="dossier.deposit_status == 'pending'"/>
                                                    <label class="form-check-label">En cours</label>
                                                </div>
                                                <div class="form-check">
                                                    <input class="form-check-input" type="radio" name="deposit_status" value="exempt" t-att-checked="dossier.deposit_status == 'exempt'"/>
                                                    <label class="form-check-label">Exempté</label>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                </div>
                            </div>
                        </div>
                        <!-- Fin Section 1 -->

                        <!-- Section 2 : Élèves -->
                        <div class="accordion-item border mb-3 rounded shadow-sm">
                            <h2 class="accordion-header" id="headingStudents">
                                <button class="accordion-button collapsed rounded" type="button" data-bs-toggle="collapse" data-bs-target="#collapseStudents" aria-expanded="false" aria-controls="collapseStudents">
                                    <i class="fa fa-child me-2 text-primary"/>
                                    <strong>Informations élève(s)</strong>
                                </button>
                            </h2>
                            <div id="collapseStudents" class="accordion-collapse collapse" aria-labelledby="headingStudents">
                                <div class="accordion-body">

                                    <div class="alert alert-info">
                                        <i class="fa fa-info-circle me-2"/>
                                        Lors de diverses activités organisées par l'école, les élèves
                                        peuvent être amenés à être photographiés ou filmés.
                                    </div>

                                    <!-- Élèves existants -->
                                    <div id="students_list">
                                        <t t-foreach="dossier.student_line_ids" t-as="line">
                                            <div class="card mb-3 student-line" t-att-data-line-id="line.id">
                                                <div class="card-header fw-semibold bg-light d-flex justify-content-between align-items-center">
                                                    <span>
                                                        <i class="fa fa-user-circle me-2 text-primary"/>
                                                        <t t-out="line.student_id.display_name or 'Nouvel élève'"/>
                                                    </span>
                                                    <button type="button" class="btn btn-sm btn-outline-danger btn-remove-student" t-att-data-line-id="line.id">
                                                        <i class="fa fa-trash"/>
                                                    </button>
                                                </div>
                                                <div class="card-body">
                                                    <input type="hidden" t-att-name="'student_line_id_' + str(line.id)" t-att-value="line.id"/>
                                                    <div class="row g-3">
                                                        <div class="col-md-4">
                                                            <label class="form-label fw-semibold">Prénom</label>
                                                            <input type="text" class="form-control" t-att-name="'student_firstname_' + str(line.id)" t-att-value="line.student_id.firstname or ''"/>
                                                        </div>
                                                        <div class="col-md-4">
                                                            <label class="form-label fw-semibold">Nom</label>
                                                            <input type="text" class="form-control" t-att-name="'student_lastname_' + str(line.id)" t-att-value="line.student_id.lastname or ''"/>
                                                        </div>
                                                        <div class="col-md-4">
                                                            <label class="form-label fw-semibold">Date de naissance</label>
                                                            <input type="date" class="form-control" t-att-name="'student_birthdate_' + str(line.id)" t-att-value="line.student_id.birthdate or ''"/>
                                                        </div>
                                                        <div class="col-md-6">
                                                            <label class="form-label fw-semibold">Sexe</label>
                                                            <select class="form-select" t-att-name="'student_gender_' + str(line.id)">
                                                                <option value="">-- Choisir --</option>
                                                                <option value="M" t-att-selected="line.student_id.gender == 'M'">Masculin</option>
                                                                <option value="F" t-att-selected="line.student_id.gender == 'F'">Féminin</option>
                                                            </select>
                                                        </div>
                                                        <div class="col-md-6 d-flex align-items-end">
                                                            <div class="form-check form-switch">
                                                                <input class="form-check-input" type="checkbox" role="switch" t-att-name="'student_image_rights_' + str(line.id)" t-att-id="'image_rights_' + str(line.id)" value="1" t-att-checked="line.image_rights"/>
                                                                <label class="form-check-label fw-semibold" t-att-for="'image_rights_' + str(line.id)">
                                                                    Droit à l'image
                                                                </label>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </t>
                                    </div>

                                    <!-- Bouton ajouter -->
                                    <div class="mt-2">
                                        <button type="button" class="btn btn-outline-primary" id="btn_add_student">
                                            <i class="fa fa-plus me-2"/>
Ajouter un élève
                                        </button>
                                    </div>

                                    <!-- Template nouvel élève (caché) -->
                                    <div id="new_student_template" style="display:none;">
                                        <div class="card mb-3 student-line new-student">
                                            <div class="card-header fw-semibold bg-light d-flex justify-content-between align-items-center">
                                                <span>
                                                    <i class="fa fa-user-circle me-2 text-success"/>
                                                    Nouvel élève
                                                </span>
                                                <button type="button" class="btn btn-sm btn-outline-danger btn-remove-new-student">
                                                    <i class="fa fa-trash"/>
                                                </button>
                                            </div>
                                            <div class="card-body">
                                                <div class="row g-3">
                                                    <div class="col-md-4">
                                                        <label class="form-label fw-semibold">Prénom</label>
                                                        <input type="text" class="form-control" name="new_student_firstname[]"/>
                                                    </div>
                                                    <div class="col-md-4">
                                                        <label class="form-label fw-semibold">Nom</label>
                                                        <input type="text" class="form-control" name="new_student_lastname[]"/>
                                                    </div>
                                                    <div class="col-md-4">
                                                        <label class="form-label fw-semibold">Date de naissance</label>
                                                        <input type="date" class="form-control" name="new_student_birthdate[]"/>
                                                    </div>
                                                    <div class="col-md-6">
                                                        <label class="form-label fw-semibold">Sexe</label>
                                                        <select class="form-select" name="new_student_gender[]">
                                                            <option value="">-- Choisir --</option>
                                                            <option value="M">Masculin</option>
                                                            <option value="F">Féminin</option>
                                                        </select>
                                                    </div>
                                                    <div class="col-md-6 d-flex align-items-end">
                                                        <div class="form-check form-switch">
                                                            <input class="form-check-input" type="checkbox" role="switch" name="new_student_image_rights[]" value="1" checked="checked"/>
                                                            <label class="form-check-label fw-semibold">
                                                                Droit à l'image
                                                            </label>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                </div>
                            </div>
                        </div>
                        <!-- Fin Section 2 -->

                    </div>
                    <!-- Fin accordéon -->

                    <!-- Boutons -->
                    <div class="d-flex gap-2 mt-3">
                        <button type="submit" class="btn btn-primary btn-lg">
                            <i class="fa fa-save me-2"/>
Enregistrer
                        </button>
                        <a href="/my/ecolage" class="btn btn-outline-secondary btn-lg">
                            <i class="fa fa-arrow-left me-2"/>
Annuler
                        </a>
