<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="portal_dossier_form_complete" name="Formulaire complet dossier écolage">
        <t t-call="portal.portal_layout">
            <t t-set="page_title">Dossier d'écolage</t>
            <div class="o_portal_wrapper">
                <form method="post" enctype="multipart/form-data">
                    <input type="hidden" name="csrf_token" t-att-value="csrf_token"/>

                    <div class="alert alert-info">
                        <i class="fa fa-info-circle"/>
                        Cliquez sur les sections ci-dessous pour les dérouler
                    </div>

                    <group>
                        <field name="name"/>
                        <field name="annee_scolaire"/>
                        <field name="family_id" options="{'no_create': True, 'no_create_edit': True}" readonly="1"/>
                        <field name="date_soumission"/>
                    </group>

                    <notebook>

                        <!-- Page Informations parents -->
                        <page string="Informations parents">
                            <group string="Représentant légal">
                                <field name="legal_representation" widget="radio"/>
                                <field name="legal_representation_other" invisible="legal_representation != 'other'"/>
                            </group>
                            <h3>Cotisation annuelle</h3>
                            <div class="alert alert-info">
                                À l'Association en faveur de l'école Rudolf Steiner de Genève :
                                Individuelle 40 CHF, Couple 60 CHF, Curateur/trice et Tuteur/trice Gratuit.
                            </div>
                            <div>
                                <strong>Total de la cotisation : </strong>
                                <field name="membership_fee_amount" readonly="1" class="oe_inline"/>
 CHF
                            </div>
                            <group string="Père (ou parent 1)" invisible="legal_representation != 'both'">
                                <field name="parent1_firstname"/>
                                <field name="parent1_lastname"/>
                                <field name="parent1_email" widget="email"/>
                                <field name="parent1_phone" widget="phone"/>
                                <field name="parent1_phone_fixed" widget="phone"/>
                                <field name="parent1_phone_pro" widget="phone"/>
                                <field name="parent1_street"/>
                                <field name="parent1_zip"/>
                                <field name="parent1_city"/>
                                <field name="parent1_country_id"/>
                                <field name="parent1_profession"/>
                                <field name="parent1_employeur"/>
                            </group>
                            <group string="Mère (ou parent 2)" invisible="legal_representation != 'both'">
                                <field name="parent2_firstname"/>
                                <field name="parent2_lastname"/>
                                <field name="parent2_email" widget="email"/>
                                <field name="parent2_phone" widget="phone"/>
                                <field name="parent2_phone_fixed" widget="phone"/>
                                <field name="parent2_phone_pro" widget="phone"/>
                                <field name="same_address_as_parent1"/>
                                <field name="parent2_street" invisible="same_address_as_parent1"/>
                                <field name="parent2_zip" invisible="same_address_as_parent1"/>
                                <field name="parent2_city" invisible="same_address_as_parent1"/>
                                <field name="parent2_country_id" invisible="same_address_as_parent1"/>
                                <field name="parent2_profession"/>
                                <field name="parent2_employeur"/>
                            </group>
                            <group invisible="legal_representation == 'both' or legal_representation == False">
                                <field name="parent1_firstname"/>
                                <field name="parent1_lastname"/>
                                <field name="parent1_email" widget="email"/>
                                <field name="parent1_phone" widget="phone"/>
                                <field name="parent1_phone_fixed" widget="phone"/>
                                <field name="parent1_phone_pro" widget="phone"/>
                                <field name="parent1_street"/>
                                <field name="parent1_zip"/>
                                <field name="parent1_city"/>
                                <field name="parent1_country_id"/>
                                <field name="parent1_profession"/>
                                <field name="parent1_employeur"/>
                            </group>
                            <group string="Dépôt">
                                <div class="alert alert-info">Toute nouvelle famille doit verser un dépôt de 1000 CHF</div>
                                <field name="deposit_status" widget="radio"/>
                                <field name="deposit_amount" readonly="1"/>
                            </group>
                        </page>

                        <!-- Page Élèves -->
                        <page string="Informations élève(s)">
                            <field name="student_line_ids" nolabel="1">
                                <list editable="bottom" create="1" delete="1">
                                    <field name="student_id" string="Élève" domain="[('family_id', '=', parent.family_id)]" options="{'no_create': False, 'no_create_edit': False, 'always_reload': True}" context="{'form_view_ref': 'ersge_portal_ecolage.view_ersge_student_form', 'default_family_id': parent.family_id}"/>
                                    <field name="sexe"/>
                                    <field name="image_rights" widget="boolean_toggle"/>
                                </list>
                            </field>
                            <div class="alert alert-info mt-3">
                                <i class="fa fa-info-circle"/>
                                Lors de diverses activités organisées par l'école, les élèves peuvent être amenés à être photographiés ou filmés.
                            </div>
                        </page>

                        <!-- Page Finances (tronquée pour lisibilité, mais vous pouvez recopier l'intégralité) -->
                        <page string="Finances">
                            <h2>Écolage</h2>
                            <div>
                                <strong>Bénéficiez-vous d'une aide de votre employeur pour l'écolage ?</strong>
                                <field name="employer_assistance" widget="radio"/>
                                <div invisible="employer_assistance != 'yes'">
                                    <field name="send_invoice_to_employer" widget="boolean_toggle"/>
                                    <label for="send_invoice_to_employer" string="Envoyer la facture à l'employeur"/>
                                </div>
                                <div invisible="employer_assistance != 'yes' or not send_invoice_to_employer">
                                    <label for="employer_id"/>
                                    <field name="employer_id" context="{'default_is_employer': True}" options="{'no_create': False}"/>
                                </div>
                            </div>
                            <h2>Forfaits</h2>
                            <div class="alert alert-info">
                                <strong>CHOISISSEZ VOTRE FORFAIT</strong>
                                <br/>
                                FRAIS DE SCOLARITÉ + MATÉRIEL SCOLAIRE DE BASE + REPAS DE MIDI* BIO<br/>
                                *Selon l'emploi du temps<br/>
                                Tarifs mensuels sur 12 mois - 1er versement au mois d'août. Frais non compris : Activités en dehors des murs de l'école (ex. voyage, échange linguistique...) et goûters aux jardins d'enfants.
                        </div>
                        <field name="student_line_ids" nolabel="1">
                            <list editable="bottom">
                                <field name="student_id" readonly="1"/>
                                <field name="forfait_id" options="{'no_create': True}"/>
                                <field name="forfait_montant_mensuel" readonly="1"/>
                            </list>
                        </field>
                        <div>
                            <strong>Total mensuel (hors réduction) : </strong>
                            <field name="base_monthly_fee" readonly="1" class="oe_inline"/>
 CHF
                        </div>
                        <!-- Réductions, etc. à copier depuis votre vue -->
                    </page>

                    <!-- Page Parascolaire -->
                    <page string="Parascolaire">
                        <field name="after_school_request" widget="radio" options="{'horizontal': true}"/>
                        <label for="after_school_request" string="Souhaitez-vous inscrire votre enfant au parascolaire ?"/>
                        <div invisible="after_school_request != 'yes'">
                            <div class="alert alert-warning mt-2" role="alert">
                                <i class="fa fa-exclamation-triangle"/>
                                <strong>Important :</strong> remplir le formulaire ne signifie pas que votre demande sera forcément acceptée...
                            </div>
                            <group string="Inscriptions par élève">
                                <field name="after_school_line_ids" nolabel="1">
                                    <list>
                                        <field name="student_id" readonly="1"/>
                                        <field name="accueil_type"/>
                                        <field name="prestation_ids" widget="many2many_tags"/>
                                        <field name="montant_mensuel" readonly="1" sum="Total"/>
                                    </list>
                                    <form>
                                        <group>
                                            <field name="student_id" readonly="1"/>
                                            <field name="accueil_type" widget="radio"/>
                                            <field name="prestation_ids" widget="many2many_checkboxes" domain="[('active', '=', True), '|', ('applicable_to', '=', accueil_type), ('applicable_to', '=', 'both')]"/>
                                            <field name="montant_mensuel" readonly="1"/>
                                        </group>
                                    </form>
                                </field>
                            </group>
                            <!-- Descriptifs (jardin, classe, cirque) à recopier si besoin -->
                        </div>
                    </page>

                    <!-- Page Récapitulatif -->
                    <page string="Récapitulatif">
                        <group string="Mensuel">
                            <label for="total_monthly_tuition"/>
                            <field name="total_monthly_tuition"/>
                            <label for="total_monthly_after_school"/>
                            <field name="total_monthly_after_school"/>
                            <label for="total_monthly"/>
                            <field name="total_monthly"/>
                        </group>
                        <group string="Annuel">
                            <label for="total_annual_tuition"/>
                            <field name="total_annual_tuition"/>
                            <label for="total_annual_after_school"/>
                            <field name="total_annual_after_school"/>
                            <label for="membership_fee_amount"/>
                            <field name="membership_fee_amount"/>
                            <label for="deposit_amount"/>
                            <field name="deposit_amount"/>
                            <label for="total_annual"/>
                            <field name="total_annual"/>
                        </group>
                    </page>

                    <page string="Mentions">
                        <field name="legal_notice" widget="html" readonly="1"/>
                        <field name="technical_contact" widget="html" readonly="1"/>
                    </page>

                </notebook>

                <div class="clearfix oe_buttons mt-3">
                    <button type="submit" class="btn btn-primary">Enregistrer</button>
                    <a href="/my/ecolage" class="btn btn-secondary">Annuler</a>
                </div>
            </form>
        </div>
    </t>
</template>
<template id="portal_famille_new" name="Créer ma famille">
    <t t-call="portal.portal_layout">

        <!-- Fil d'Ariane -->
        <t t-set="o_portal_fullwidth_alert" t-value="False"/>

        <div class="container mt-4">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">
                        <i class="fa fa-home me-2 text-primary"/>
                        Créer votre famille
                    </h5>
                </div>
                <div class="card-body">

                    <!-- Message d'explication -->
                    <div class="alert alert-info mb-4" role="alert">
                        <i class="fa fa-info-circle me-2"/>
                        Pour déposer un dossier d'écolage, vous devez d'abord
                        <strong>créer votre famille</strong>.
                        Cette étape est rapide et ne prend qu'une minute.
                    </div>

                    <!-- Message d'erreur éventuel -->
                    <t t-if="error">
                        <div class="alert alert-danger mb-4" role="alert">
                            <i class="fa fa-exclamation-triangle me-2"/>
                            <t t-out="error"/>
                        </div>
                    </t>

                    <!-- Formulaire -->
                    <form action="/my/famille/new" method="POST" class="o_portal_details">
                        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                        <input type="hidden" name="next" t-att-value="next"/>

                        <div class="row g-3">

                            <!-- Nom de famille -->
                            <div class="col-12">
                                <label for="nom" class="form-label fw-semibold">
                                    Nom de famille <span class="text-danger">*</span>
                                </label>
                                <input type="text" name="nom" id="nom" class="form-control form-control-lg" placeholder="Ex : Dupont" required="required" autofocus="autofocus" />
                                <div class="form-text text-muted">
                                    Le nom qui identifiera votre famille dans le système.
                                </div>
                            </div>

                            <!-- Info partenaire connecté -->
                            <div class="col-12">
                                <label class="form-label fw-semibold">Compte rattaché</label>
                                <div class="form-control bg-light text-muted">
                                    <i class="fa fa-user me-2"/>
                                    <t t-out="partner.name"/>
                                    <span class="ms-2 small">(                                        <t t-out="partner.email"/>
)</span>
                                </div>
                                <div class="form-text text-muted">
                                    Vous serez automatiquement ajouté comme parent de cette famille.
                                </div>
                            </div>

                        </div>

                        <!-- Boutons -->
                        <div class="d-flex gap-2 mt-4 pt-3 border-top">
                            <button type="submit" class="btn btn-primary btn-lg">
                                <i class="fa fa-check me-2"/>
                                Créer ma famille et continuer
                            </button>
                            <a href="/my/ecolage" class="btn btn-outline-secondary btn-lg">
                                <i class="fa fa-arrow-left me-2"/>
                                Annuler
                            </a>
                        </div>

                    </form>

                </div>
            </div>
        </div>

    </t>
</template>
</odoo>