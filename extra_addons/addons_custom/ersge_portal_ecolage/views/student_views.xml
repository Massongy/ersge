<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_ersge_student_form" model="ir.ui.view">
            <field name="name">ersge.student.form</field>
            <field name="model">ersge.student</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <group>
                                <field name="family_id" readonly="1"/>
                            </group>
                            <group>
                                <field name="firstname" string="Prénom"/>
                                <field name="lastname" string="Nom"/>
                                <field name="birthdate" string="Date de naissance"/>
                                <field name="gender" string="Sexe"/>
                                <field name="image_rights" string="Droit à l'image" widget="boolean_toggle"/>
                            </group>
                        </group>
                        <group>
                            <field name="pronote_id" string="Identifiant ProNote"/>
                            <field name="active" string="Actif"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>
    </data>
</odoo>