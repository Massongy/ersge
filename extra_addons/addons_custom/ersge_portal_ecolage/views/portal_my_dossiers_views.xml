<odoo>
    <template id="portal_my_dossiers" name="Mes dossiers d'écolage">
        <t t-call="portal.portal_layout">
            <t t-set="page_title">Mes dossiers d'écolage</t>
            <div class="o_portal_wrapper">

                <!-- Message d'erreur -->
                <t t-if="error">
                    <div class="alert alert-warning" role="alert">
                        <t t-out="error"/>
                    </div>
                </t>

                <!-- Message de succès -->
                <t t-if="success">
                    <div class="alert alert-success" role="alert">
                        <t t-out="success"/>
                    </div>
                </t>

                <!-- Lien vers la gestion des familles (toujours présent) -->
                <a href="/my/ecolage/families" class="btn btn-outline-secondary mb-3">
                    <i class="fa fa-users me-1"/>
 Gérer mes familles
                </a>

                <!-- Lien de retour quand la liste est filtrée par une famille -->
                <t t-if="current_family_id">
                    <a href="/my/ecolage/families" class="btn btn-outline-secondary mb-3">
                        <i class="fa fa-arrow-left me-1"/>
 Toutes mes familles
                    </a>
                </t>

                <!-- Bouton nouveau dossier -->
                <a href="/my/ecolage/dossier/choose" class="btn btn-primary mb-3">+ Nouveau dossier</a>

                <!-- Message informatif si filtre actif -->
                <t t-if="current_family_id">
                    <div class="alert alert-info">
                        <i class="fa fa-filter me-2"></i>
                        Affichage des dossiers de la famille sélectionnée.
                        <a href="/my/ecolage/families">Voir toutes mes familles</a>
                    </div>
                </t>

                <t t-if="not dossiers">
                    <div class="alert alert-info">Vous n'avez aucun dossier pour le moment.</div>
                </t>

                <t t-foreach="dossiers" t-as="dossier">
                    <div class="card mb-2">
                        <div class="card-body">
                            <h5 class="card-title">
                                <span t-field="dossier.name"/>
                                <small class="text-muted"> - Famille <t t-esc="dossier.family_id.name"/>
                                </small>
                                <t t-if="dossier.state == 'soumis'">
                                    <span class="badge ml-2 badge-warning">
                                        <t t-out="dossier.state"/>
                                    </span>
                                </t>
                                <t t-elif="dossier.state == 'valide'">
                                    <span class="badge ml-2 badge-success">
                                        <t t-out="dossier.state"/>
                                    </span>
                                </t>
                                <t t-else="">
                                    <span class="badge ml-2 badge-secondary">
                                        <t t-out="dossier.state"/>
                                    </span>
                                </t>
                            </h5>
                            <p class="card-text">Année scolaire : <span t-field="dossier.annee_scolaire"/>
                            </p>
                            <div class="d-flex flex-wrap gap-2">
                                <!-- Modifier -->
                                <t t-if="dossier.state != 'soumis'">
                                    <a t-att-href="'/my/ecolage/edit/%s' % dossier.id" class="btn btn-secondary btn-sm rounded">
                                        Modifier
                                    </a>
                                </t>
                                <!-- Consulter -->
                                <a t-att-href="'/my/ecolage/dossier/%s' % dossier.id" class="btn btn-primary btn-sm rounded">
                                    Consulter et imprimer
                                </a>
                                <!-- Supprimer -->
                                <t t-if="dossier.state != 'soumis'">
                                    <form t-attf-action="/my/ecolage/delete/{{dossier.id}}" method="post" style="display: inline-block;">
                                        <input type="hidden" name="csrf_token" t-att-value="csrf_token"/>
                                        <button type="submit" class="btn btn-danger btn-sm rounded" onclick="return confirm('Supprimer définitivement ce dossier ?')">
                                            Supprimer
                                        </button>
                                    </form>
                                </t>
                                <!-- Partager -->
                                <t t-if="dossier.state != 'soumis'">
                                    <a t-attf-href="/my/ecolage/#{dossier.id}/acces" class="btn btn-outline-info btn-sm rounded">
                                        <i class="fa fa-share-alt me-1"/>
 Partager
                                    </a>
                                </t>
                            </div>
                        </div>
                    </div>
                </t>
            </div>
        </t>
    </template>
</odoo>