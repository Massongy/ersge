        <!-- ================================================================
             FORFAITS SCOLAIRES
        ================================================================ -->
        <record id="demo_forfait_maternelle" model="ersge.forfait">
            <field name="name">Maternelle (3-6 ans)</field>
            <field name="montant_mensuel">800.0</field>
            <field name="description">Forfait pour les élèves de maternelle</field>
            <field name="active">True</field>
        </record>

        <record id="demo_forfait_primaire" model="ersge.forfait">
