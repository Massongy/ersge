            <field name="parent2_id" ref="demo_parent_dubois_mere"/>
            <field name="parent2_profession">Architecte</field>
            <field name="after_school_request">no</field>
            <field name="membership_fee">unpaid</field>
            <field name="deposit_status">unpaid</field>
            <field name="payment_terms">annually</field>
            <field name="reduction_requested">False</field>
            <field name="address_book_optin">False</field>
        </record>

        <!-- Dossier Robert 2025-2026 -->
        <record id="demo_dossier_robert" model="ersge.dossier.famille">
            <field name="name">DOS-2025-003</field>
            <field name="annee_scolaire">2025-2026</field>
            <field name="family_id" ref="demo_family_robert"/>
            <field name="state">en_cours</field>
            <field name="legal_representation">both</field>
            <field name="parent1_id" ref="demo_parent_robert_pere"/>
            <field name="parent1_profession">Consultant</field>
            <field name="parent2_id" ref="demo_parent_robert_mere"/>
            <field name="parent2_profession">Enseignante</field>
            <field name="after_school_request">yes</field>
            <field name="membership_fee">paid</field>
            <field name="deposit_status">paid</field>
            <field name="payment_terms">monthly</field>
            <field name="reduction_requested">True</field>
            <field name="children_count">2</field>
            <field name="seniority_years">5</field>            <!-- CORRIGÉ : '3' invalide → '5' = Moins de 6 ans -->
            <field name="apply_children_discount">True</field>
            <field name="apply_seniority_discount">True</field>
            <field name="requested_discount">8.0</field>
            <field name="address_book_optin">True</field>
            <field name="contract_accepted">True</field>
            <field name="terms_accepted">True</field>
        </record>

