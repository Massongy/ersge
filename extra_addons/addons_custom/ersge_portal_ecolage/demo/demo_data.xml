            <field name="active">True</field>
        </record>

        <record id="demo_forfait_secondaire" model="ersge.forfait">
            <field name="name">Secondaire (12-16 ans)</field>
            <field name="montant_mensuel">1100.0</field>
            <field name="description">Forfait pour les élèves du secondaire</field>
            <field name="active">True</field>
        </record>

